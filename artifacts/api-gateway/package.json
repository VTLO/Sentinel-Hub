    "@sentinel-hub/db-models": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
